# ❯ Imagen Base {
FROM docker.io/library/archlinux:latest
# }

# ❯ DNS Resiliente & Pacman Paralelo {
# Soluciona `network_isolation=enabled` por defecto en Podman 6.0.0+.
# Independiente del DNS del host: el build funciona con/sin `--network=host`.
RUN echo 'nameserver 1.1.1.1' >  /etc/resolv.conf && \
    echo 'nameserver 9.9.9.9' >> /etc/resolv.conf && \
    sed -i 's/^#ParallelDownloads/ParallelDownloads/' /etc/pacman.conf
# }

# ❯ Sistema, Mirrorlist Óptimo & BlackArch {
RUN pacman -Syu --noconfirm curl git ca-certificates reflector && \
    reflector --protocol https --latest 15 --sort rate \
              --save /etc/pacman.d/mirrorlist && \
    pacman -Syu --noconfirm && \
    curl -fsSL --retry 5 --retry-delay 10 --retry-all-errors \
         -O https://blackarch.org/strap.sh && \
    chmod +x strap.sh && \
    ./strap.sh && \
    pacman -Syu --noconfirm
# }

# ❯ Stack: ZSH + PDE Rust + Hacking Ético {
RUN pacman -S --noconfirm \
        zsh fzf zoxide starship \
        eza bat ripgrep fd yazi \
        helix fastfetch \
        rustscan feroxbuster nmap iputils && \
    pacman -Scc --noconfirm
# }

# ❯ Gestor de Plugins: Antidote {
RUN git clone --depth=1 https://github.com/mattmc3/antidote.git /root/.antidote
# }

# ❯ Estructura XDG_CONFIG_HOME {
RUN mkdir -p /root/.zshrc.d \
             /root/.config/yazi \
             /root/.config/helix
# }

# ❯ Inyección de Dotfiles {
COPY .zshrc           /root/.zshrc
COPY .zsh_plugins.txt /root/.zsh_plugins.txt
COPY zshrc.d/         /root/.zshrc.d/
COPY starship.toml    /root/.config/starship.toml
COPY yazi/            /root/.config/yazi/
COPY helix/           /root/.config/helix/
COPY fastfetch/       /root/.config/fastfetch/
# }

# ❯ Pre-compilación de Plugins (Rendimiento) {
RUN zsh -c 'source /root/.antidote/antidote.zsh && \
            antidote bundle < /root/.zsh_plugins.txt > /root/.zsh_plugins.zsh'
# }

# ❯ Configuración de Entrada {
WORKDIR /root
ENV EDITOR=hx
CMD ["/usr/bin/zsh"]
# }
